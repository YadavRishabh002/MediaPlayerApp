<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Media"
        android:textColor="#BBBBBB"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3">

        <Button android:id="@+id/btnOpenFile" android:text="Audio File" android:layout_columnWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnOpenUrl" android:text="Video URL" android:layout_columnWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnPlay" android:text="PLAY" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#4CAF50"/>
        <Button android:id="@+id/btnPause" android:text="PAUSE" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#FF9800"/>
        <Button android:id="@+id/btnStop" android:text="STOP" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#F44336"/>
        <Button android:id="@+id/btnRestart" android:text="RESTART" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    </GridLayout>
</LinearLayout>